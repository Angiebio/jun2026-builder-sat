# Copy to .env and fill in. Runs FULLY LOCAL with zero keys (granite via Ollama);
# keys below only enable optional frontier features. Never commit your real .env.

# Local model (default — no key needed)
MODEL_PROVIDER=local
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=granite4:micro

# Frontier vision + prose ($50 Claude event credits)
ANTHROPIC_API_KEY=

# Optional: illustration
FAL_KEY=

# Optional: live research
TAVILY_API_KEY=
