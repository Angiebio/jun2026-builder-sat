# secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem
*secret*

# python
__pycache__/
*.py[cod]
.venv/
venv/
.uv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# runtime output — but KEEP the 4 demo run dirs so the web UI works on a fresh clone
runs/*
!runs/pinwheel/
!runs/punched_cards/
!runs/ti_82/
!runs/nokia_3590/
*.log

# node / build
node_modules/
dist/

# os / onedrive
.DS_Store
Thumbs.db
desktop.ini
*.tmp

# local demo inputs — ignore by default, but SHIP the 4 curated antique photos so
# the web UI shows thumbnails on a fresh clone (all other local inputs stay private)
test images/*
!test images/IMG_4523.JPG
!test images/IMG_4524.JPG
!test images/IMG_4526.JPG
!test images/IMG_4527.JPG
# visitor uploads from the web UI — local only, never judged
uploads/
